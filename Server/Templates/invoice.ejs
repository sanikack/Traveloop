<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Invoice</title>
  <style>
    body { font-family: Arial; padding: 40px; }
    h1 { color: #0b8a2f; }
    .box { border: 1px solid #ddd; padding: 20px; margin-bottom: 20px; }
    table { width: 100%; }
    td { padding: 8px; }
    .total { font-weight: bold; color: #0b8a2f; }
  </style>
</head>

<body>

  <h1>Travel Invoice</h1>
  <p><strong>Booking ID:</strong> <%= booking.bookingId %></p>

  <div class="box">
    <h3>Customer Details</h3>
    <table>
      <tr><td>Name</td><td><%= booking.name %></td></tr>
      <tr><td>Email</td><td><%= booking.email %></td></tr>
      <tr><td>Phone</td><td><%= booking.phone %></td></tr>
    </table>
  </div>

  <div class="box">
    <h3>Package Details</h3>
    <table>
      <tr><td>Package</td><td><%= booking.packageTitle %></td></tr>
      <tr><td>Date</td><td><%= booking.date %></td></tr>
      <tr><td>Persons</td>
        <td>Adults: <%= booking.adults %> |
            Childrens: <%= booking.childrens %>
          </td>
          </tr>
    </table>
  </div>

  <div class="box">
    <table>
      <tr>
        <td class="total">Total Amount</td>
        <td class="total">₹ <%= booking.payableAmount %></td>
      </tr>
    </table>
  </div>

  <p style="text-align: center; margin-top: 70px;">Thank you for choosing us ✨</p>

</body>
</html>
